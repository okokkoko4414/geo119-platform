parameters:
    level: 0
    paths:
        - app/
    excludePaths:
        - app/wordpress/*
    checkUninitializedProperties: true
    checkExplicitMixedMissingReturn: false
    tipsOfTheDay: false
    ignoreErrors:
        - '#Static call to instance method Redis::ping\(\)#'
        - '#Unknown parameter \$same_site in call to function setcookie#'
