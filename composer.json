{
    "name": "geo119/geo119",
    "description": "GEO119 - Multi-language content optimization platform",
    "type": "project",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.0",
        "laravel/telescope": "^5.0",
        "laravel/tinker": "^2.0",
        "predis/predis": "^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": ["vendor/bin/phpcs --standard=PSR12 app/", "vendor/bin/pint --test"],
        "stan": "vendor/bin/phpstan analyse --level=max app/",
        "test": ["vendor/bin/phpunit", "vendor/bin/pest"],
        "build": "npm run build"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pestphp/pest-plugin-mutate": true,
            "phpstan/extension-installer": true
        }
    }
}
